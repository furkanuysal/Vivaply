{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MetadataRefresh": {
    "BatchSize": 50,
    "MaxConcurrency": 5,
    "MovieTtlDays": 14,
    "ShowTtlDays": 7,
    "GameTtlDays": 14,
    "BookTtlDays": 60
  },
  "ActivityRetention": {
    "DeletedRetentionDays": 90,
    "PurgeBatchSize": 500
  }
}
